<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents">
        <item name="colorPrimary">@color/black</item> 
        <item name="backgroundColor">@color/white</item> 
        <item name="colorPrimaryDark">@color/black</item> 
        <item name="colorAccent">@color/white</item> 
        <item name="android:textColorLink">@color/white</item> 
        <item name="android:textColor">@color/white</item> 
        <item name="elevation">0dp</item> 

    </style>
    <style name="AppTheme.ActivityDetails" parent="Theme.MaterialComponents">
        <item name="background">@drawable/gradient_background</item> 
        <item name="itemIconTint">@color/black</item> 
        <item name="itemTextColor">@color/black</item> 
        <item name="itemRippleColor">@color/dark_blue</item> 
        <item name="subtitleTextColor">@color/black</item> 
        <item name="elevation">0dp</item> 
    </style>
    <style name="Base.Theme.SeaOfCinema" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        
        
    </style>
    <style name="Theme.AppCompat.NoActionBar.Fullscreen" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowContentOverlay">@null</item>ф
    </style>
    <style name="Widget.App.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/appbar_background_color</item> 
        <item name="itemIconTint">@color/white</item> 
        <item name="itemTextColor">@color/white</item> 
        <item name="itemRippleColor">@color/white</item> 
        <item name="elevation">0dp</item> 
    </style>
    <style name="Widget.App.MaterialToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="background">@color/black</item> 
        <item name="itemIconTint">@color/black</item> 
        <item name="itemTextColor">@color/black</item> 
        <item name="itemRippleColor">@color/dark_blue</item> 
        <item name="subtitleTextColor">@color/black</item> 
        <item name="elevation">0dp</item> 
